  m_text: "-\uB178\uD2B8\uBD81\uC5D0 \uBE14\uB8E8\uC2A4\uD06C\uB9B0\uB5A0\uC11C \uC2AC\uD508
    \uC9D1\uC0AC\uC758 \uB9C8\uC74C \n\uC4F0\uB808\uAE30 \uCE58\uC6B0\uB290\uB77C
    \uAC78\uB9AC\uB294 \uC9D1\uC0AC\uC758 \uC2DC\uAC04 15\uBD84\n\uBA38\uADF8\uCEF5
    -19,900\uC6D0\n\uD2B8\uB85C\uD53C -199,800\uC6D0\n\uAF43\uBCD1 -5,990\uC6D0\n\uD654\uBD84
    -79,900\uC6D0\n-\uD654\uBD84\uB0A8\uC758 \uAE30\uC5B5\n\uB9C8\uD2B8 \uCC9C\uB9C9
    -300,000\uC6D0\n-\uD3EC\uC2A4\uD130 \uBD99\uC778 \uC0AC\uB78C\uC758 \uB9C8\uC74C\n-\uC624\uC774
    \uBCF4\uACE0 \uB180\uB780 \uACE0\uC591\uC774\uC758 \uB9C8\uC74C\n-\uD654\uBD84\uB0A8\uC758
